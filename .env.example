# ════════════════════════════════════════════════════════════════════
#  5G O-RAN Platform — environment variables
#
#  Copy to `.env` (gitignored) and edit for your machine.
#  Anything left commented falls back to the value derived from
#  PROJECT_ROOT (the directory containing this file).
# ════════════════════════════════════════════════════════════════════

# Repo checkout root. Used by every script + the FastAPI controller.
# If unset, scripts in tools/ default to their parent dir, and the
# controller defaults to three levels up from platform/controller/controller.py.
#PROJECT_ROOT=/home/ops-boy/project/graduation-project

# Where the C xApps write their CSV outputs. The compiled xApp binaries
# may embed `/home/<user>/handover.csv` at compile time, so this must
# match the user that built them. Defaults to $HOME.
#RUNTIME_CSV_HOME=/home/ops-boy

# ── Component overrides (optional — derived from PROJECT_ROOT) ────────
#FLEXRIC_BIN=$PROJECT_ROOT/platform/flexric/build/examples/ric/nearRT-RIC
#FLEXRIC_CONF=$PROJECT_ROOT/platform/flexric/flexric.conf
#NS3_DIR=$PROJECT_ROOT/platform/ns3-sim/mmwave-LENA-oran
#GUI_DIR=$PROJECT_ROOT/platform/2d-gui
#XAPP_GRU_BIN=$PROJECT_ROOT/platform/flexric/build/examples/xApp/c/handover_gru/xapp_handover_gru
#XAPP_RL_BIN=$PROJECT_ROOT/platform/flexric/build/examples/xApp/c/handover_rl/xapp_handover_rl
#XAPP_RC_BIN=$PROJECT_ROOT/platform/flexric/build/examples/xApp/c/ctrl/xapp_rc_handover_ctrl
#GRU_SERVICE=$PROJECT_ROOT/xapps/gru-handover/python-service/gru_xapp.py
#RL_SERVICE=$PROJECT_ROOT/xapps/rl-handover/python-service/rl_xapp.py

# ── Persistence ───────────────────────────────────────────────────────
#RESULTS_DIR=$PROJECT_ROOT/sim-results
#DECISIONS_DB=$PROJECT_ROOT/sim_decisions.db
#HANDOVER_CSV=$RUNTIME_CSV_HOME/handover.csv
#LSTM_CSV=$RUNTIME_CSV_HOME/lstm_features.csv
#KPM_CSV=$RUNTIME_CSV_HOME/kpm_handover_features.csv

# ── Service ports ─────────────────────────────────────────────────────
#GRU_PORT=5000
#RL_PORT=5001
# (controller=8001, frontend=3001, 2D GUI=8000, InfluxDB=8086, Grafana=3000
#  are baked into Vite/Docker config — change them there if needed.)

# ── xApp → Python service URLs (passed as env to the C xApp processes) ─
#LSTM_SERVICE_URL=http://localhost:5000
#RL_SERVICE_URL=http://localhost:5001

# ── Container registry (Docker Hub) ───────────────────────────────────
#REGISTRY=mohamed710
#IMAGE_TAG=dev
